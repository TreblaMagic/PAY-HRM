# Supabase Configuration
# Get these values from supabase start output or your Supabase project settings

# Local Supabase (when running supabase start)
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# For production, use your Supabase project URL and anon key:
# VITE_SUPABASE_URL=https://your-project-ref.supabase.co
# VITE_SUPABASE_ANON_KEY=your-production-anon-key

# Optional: Service Role Key (only needed for admin operations, keep secret!)
# VITE_SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Optional: Direct Postgres connection (if needed)
# DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
